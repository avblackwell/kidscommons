---
interface Props {
  title: string
  description?: string
  breadcrumbs?: { label: string; href: string }[]
}

const { title, description, breadcrumbs } = Astro.props
---

<section class="border-b bg-muted/30">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 sm:py-16 lg:px-8">
    {breadcrumbs && breadcrumbs.length > 0 && (
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-1.5 text-sm text-muted-foreground">
          <li>
            <a href="/" class="transition-colors hover:text-foreground">Home</a>
          </li>
          {breadcrumbs.map((crumb, i) => (
            <li class="flex items-center gap-1.5">
              <span class="text-muted-foreground/50">/</span>
              {i === breadcrumbs.length - 1 ? (
                <span class="text-foreground">{crumb.label}</span>
              ) : (
                <a href={crumb.href} class="transition-colors hover:text-foreground">
                  {crumb.label}
                </a>
              )}
            </li>
          ))}
        </ol>
      </nav>
    )}
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{title}</h1>
    {description && (
      <p class="mt-4 max-w-2xl text-lg text-muted-foreground">{description}</p>
    )}
  </div>
</section>
