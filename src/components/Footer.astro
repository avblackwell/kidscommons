---
import { SITE } from "@/lib/constants"
import Logo from "@/components/Logo.astro"
import Facebook from "@/components/icons/Facebook.astro"
import Instagram from "@/components/icons/Instagram.astro"
import NewsletterSignup from "@/components/NewsletterSignup"
---

<footer class="border-t bg-zinc-900 text-white">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-4">
      <!-- Brand + Contact -->
      <div class="space-y-4">
        <Logo invert />
        <p class="text-sm leading-relaxed text-white/60">
          {SITE.description}
        </p>
        <div class="space-y-1 text-sm text-white/60">
          <p>{SITE.address.street}</p>
          <p>{SITE.address.city}, {SITE.address.state} {SITE.address.zip}</p>
          <p>
            <a href={`tel:${SITE.phone}`} class="transition-colors hover:text-white">
              {SITE.phone}
            </a>
          </p>
        </div>
      </div>

      <!-- Hours -->
      <div class="space-y-4">
        <h3 class="text-sm font-bold uppercase tracking-wider text-white/40">Hours</h3>
        <dl class="space-y-3 text-sm">
          {SITE.hours.map((schedule) => (
            <div>
              <dt class="font-semibold text-white/80">{schedule.days}</dt>
              <dd class="text-white/50">{schedule.time}</dd>
            </div>
          ))}
        </dl>
      </div>

      <!-- Quick Links -->
      <div class="space-y-4">
        <h3 class="text-sm font-bold uppercase tracking-wider text-white/40">Explore</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/visit" class="text-white/60 transition-colors hover:text-white">Plan Your Visit</a></li>
          <li><a href="/visit/exhibits" class="text-white/60 transition-colors hover:text-white">Exhibits</a></li>
          <li><a href="/memberships" class="text-white/60 transition-colors hover:text-white">Memberships</a></li>
          <li><a href="/education" class="text-white/60 transition-colors hover:text-white">Education</a></li>
          <li><a href="/parties-rentals" class="text-white/60 transition-colors hover:text-white">Parties & Rentals</a></li>
          <li><a href="/support/donate" class="text-white/60 transition-colors hover:text-white">Donate</a></li>
          <li><a href="/about/contact" class="text-white/60 transition-colors hover:text-white">Contact Us</a></li>
        </ul>
      </div>

      <!-- Newsletter -->
      <div class="space-y-4">
        <h3 class="text-sm font-bold uppercase tracking-wider text-white/40">Stay Connected</h3>
        <p class="text-sm text-white/60">
          Get the latest on events, camps, and museum news.
        </p>
        <NewsletterSignup client:visible />
        <div class="flex gap-3 pt-2">
          <a
            href={SITE.social.facebook}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="flex size-10 items-center justify-center rounded-full bg-white/10 text-white/60 transition-colors hover:bg-kc-blue hover:text-white"
          >
            <Facebook />
          </a>
          <a
            href={SITE.social.instagram}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="flex size-10 items-center justify-center rounded-full bg-white/10 text-white/60 transition-colors hover:bg-kc-purple hover:text-white"
          >
            <Instagram />
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-white/10 pt-8 sm:flex-row">
      <p class="text-sm text-white/40">
        &copy; {new Date().getFullYear()} KidsCommons. All rights reserved.
      </p>
      <p class="text-sm text-white/40">
        A 501(c)(3) nonprofit children's museum in Columbus, Indiana.
      </p>
    </div>
  </div>
</footer>
