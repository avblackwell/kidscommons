---
/**
 * KidsCommons logo
 * Using the actual logo image for pixel-perfect rendering.
 * TODO: Replace PNG with SVG version from client for crisp scaling.
 */
interface Props {
  class?: string
  size?: "sm" | "md" | "lg"
  invert?: boolean
}

const { class: className, size = "md", invert = false } = Astro.props

const sizes = {
  sm: "h-8",
  md: "h-12",
  lg: "h-16",
}
---

<a
  href="/"
  class:list={["inline-block", className]}
  aria-label="kidscommons — columbus' community children's museum"
>
  <img
    src="/images/logo.png"
    alt="kidscommons"
    class:list={[sizes[size], "w-auto", invert && "brightness-0 invert"]}
    width="372"
    height="90"
    loading="eager"
  />
</a>
