---
import { NAV_ITEMS, SITE } from "@/lib/constants"
import Logo from "@/components/Logo.astro"
import MobileNav from "@/components/MobileNav"
import LinkButton from "@/components/LinkButton.astro"

const currentPath = Astro.url.pathname
---

<header class="sticky top-0 z-50 w-full border-b border-border/50 bg-background shadow-sm">
  <div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <Logo />

    <!-- Desktop Nav -->
    <nav class="hidden items-center gap-1 lg:flex" aria-label="Main navigation">
      {NAV_ITEMS.map((item) => {
        const isActive = currentPath.startsWith(item.href)
        return (
          <div class="group relative">
            <a
              href={item.href}
              class:list={[
                "inline-flex items-center gap-1 rounded-full px-3 py-2 text-sm font-semibold transition-colors",
                isActive
                  ? "text-kc-red"
                  : "text-foreground/70 hover:bg-kc-red-light hover:text-kc-red",
              ]}
              aria-current={isActive ? "page" : undefined}
            >
              {item.label}
              {item.children && (
                <svg class="size-3.5 opacity-50 transition-transform group-hover:rotate-180 group-focus-within:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
                </svg>
              )}
            </a>
            {item.children && (
              <div class="invisible absolute left-0 top-full pt-2 opacity-0 transition-all group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
                <div class="min-w-48 rounded-2xl border bg-popover p-2 shadow-lg">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class:list={[
                        "block rounded-xl px-3 py-2 text-sm transition-colors",
                        currentPath === child.href
                          ? "bg-kc-red-light text-kc-red font-semibold"
                          : "text-popover-foreground/70 hover:bg-kc-red-light hover:text-kc-red",
                      ]}
                      aria-current={currentPath === child.href ? "page" : undefined}
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        )
      })}
    </nav>

    <!-- CTA + Mobile -->
    <div class="flex items-center gap-3">
      <LinkButton
        href={SITE.ticketsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden bg-kc-red text-white hover:bg-kc-red/85 sm:inline-flex"
      >
        Get Tickets
      </LinkButton>
      <div class="lg:hidden">
        <MobileNav client:load />
      </div>
    </div>
  </div>
</header>
