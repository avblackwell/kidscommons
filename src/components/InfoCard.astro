---
interface Props {
  title: string
  description: string
  href?: string
  color?: "red" | "blue" | "purple" | "green"
}

const { title, description, href, color = "red" } = Astro.props

const colorMap = {
  red: { bg: "bg-kc-red-light", text: "text-kc-red", dot: "bg-kc-red", hover: "hover:border-kc-red/30 hover:shadow-kc-red/5" },
  blue: { bg: "bg-kc-blue-light", text: "text-kc-blue", dot: "bg-kc-blue", hover: "hover:border-kc-blue/30 hover:shadow-kc-blue/5" },
  purple: { bg: "bg-kc-purple-light", text: "text-kc-purple", dot: "bg-kc-purple", hover: "hover:border-kc-purple/30 hover:shadow-kc-purple/5" },
  green: { bg: "bg-kc-green-light", text: "text-kc-green", dot: "bg-kc-green", hover: "hover:border-kc-green/30 hover:shadow-kc-green/5" },
}

const c = colorMap[color]
const Tag = href ? "a" : "div"
---

<Tag
  href={href}
  class:list={[
    "group block rounded-2xl border bg-card p-6 transition-all",
    href && ["hover:shadow-lg", c.hover],
  ]}
>
  <!-- Circle icon — echoing the logo dot motif -->
  <div class:list={["inline-flex size-12 items-center justify-center rounded-full", c.bg]}>
    <div class:list={["size-4 rounded-full", c.dot]} />
  </div>
  <h3 class:list={["mt-4 text-lg font-bold", href && c.text]}>{title}</h3>
  <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{description}</p>
</Tag>
