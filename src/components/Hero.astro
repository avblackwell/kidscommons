---
import { Button } from "@/components/ui/button"

interface Props {
  title: string
  subtitle?: string
  cta?: { label: string; href: string }
  secondaryCta?: { label: string; href: string }
  image?: string
  overlay?: boolean
}

const { title, subtitle, cta, secondaryCta, image, overlay = true } = Astro.props
---

<section class="relative overflow-hidden bg-kc-red">
  {image && (
    <img
      src={image}
      alt=""
      class="absolute inset-0 size-full object-cover"
      loading="eager"
    />
  )}
  {image && overlay && (
    <div class="absolute inset-0 bg-gradient-to-r from-kc-red/90 to-kc-purple/70" />
  )}

  <!-- Decorative dots — the KidsCommons circle motif -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
    <div class="absolute -top-12 -right-12 size-48 rounded-full bg-kc-blue/20" />
    <div class="absolute top-1/3 -left-8 size-32 rounded-full bg-kc-purple/15" />
    <div class="absolute -bottom-6 right-1/4 size-24 rounded-full bg-kc-green/20" />
    <div class="absolute top-12 right-1/3 size-12 rounded-full bg-white/10" />
    <div class="absolute bottom-1/4 left-1/4 size-16 rounded-full bg-kc-blue/10" />
  </div>

  <div class="relative mx-auto max-w-7xl px-4 py-24 sm:px-6 sm:py-32 lg:px-8 lg:py-40">
    <div class="max-w-2xl">
      <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        {title}
      </h1>
      {subtitle && (
        <p class="mt-6 text-lg leading-relaxed text-white/85 sm:text-xl">
          {subtitle}
        </p>
      )}
      {(cta || secondaryCta) && (
        <div class="mt-10 flex flex-wrap gap-4">
          {cta && (
            <a href={cta.href}>
              <Button client:load size="lg" className="rounded-full bg-white text-kc-red hover:bg-white/90 text-base px-8 h-12 font-bold">
                {cta.label}
              </Button>
            </a>
          )}
          {secondaryCta && (
            <a href={secondaryCta.href}>
              <Button client:load size="lg" variant="outline" className="rounded-full text-base px-8 h-12 border-white/30 text-white hover:bg-white/10 hover:text-white font-bold">
                {secondaryCta.label}
              </Button>
            </a>
          )}
        </div>
      )}
    </div>
  </div>

  <!-- Decorative wave — translate-y-px closes subpixel gap -->
  <div class="absolute -bottom-px left-0 right-0 translate-y-px">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="block w-full">
      <path d="M0 80h1440V30c-240 30-480 50-720 30S240 0 0 30v50z" fill="var(--background)" />
    </svg>
  </div>
</section>
