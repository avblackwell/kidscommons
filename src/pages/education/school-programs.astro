---
import Layout from "@/layouts/main.astro"
import PageHeader from "@/components/PageHeader.astro"
import { Button } from "@/components/ui/button"
---

<Layout title="School Programs | KidsCommons">
  <PageHeader
    title="School Programs"
    description="Educator-led programs aligned with Indiana Academic Standards."
    breadcrumbs={[
      { label: "Education", href: "/education" },
      { label: "School Programs", href: "/education/school-programs" },
    ]}
  />

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <!-- TODO: Programs will come from CMS -->
    <div class="mx-auto max-w-3xl">
      <p class="text-muted-foreground">
        Our school programs are designed by educators and aligned with Indiana Academic Standards.
        Each program combines hands-on activities with grade-appropriate content to reinforce
        classroom learning.
      </p>

      <div class="mt-12 space-y-6">
        <div class="rounded-2xl border bg-card p-6">
          <div class="flex items-center gap-3">
            <span class="rounded-lg bg-kc-blue/10 px-2.5 py-1 text-xs font-semibold text-kc-blue">Pre-K - K</span>
          </div>
          <h3 class="mt-3 text-lg font-semibold">Program details coming soon</h3>
          <p class="mt-1 text-sm text-muted-foreground">
            Contact our education coordinator for current program offerings and availability.
          </p>
        </div>

        <div class="rounded-2xl border bg-card p-6">
          <div class="flex items-center gap-3">
            <span class="rounded-lg bg-kc-blue/10 px-2.5 py-1 text-xs font-semibold text-kc-blue">1st - 3rd Grade</span>
          </div>
          <h3 class="mt-3 text-lg font-semibold">Program details coming soon</h3>
          <p class="mt-1 text-sm text-muted-foreground">
            Contact our education coordinator for current program offerings and availability.
          </p>
        </div>

        <div class="rounded-2xl border bg-card p-6">
          <div class="flex items-center gap-3">
            <span class="rounded-lg bg-kc-green/10 px-2.5 py-1 text-xs font-semibold text-kc-green">4th - 5th Grade</span>
          </div>
          <h3 class="mt-3 text-lg font-semibold">Program details coming soon</h3>
          <p class="mt-1 text-sm text-muted-foreground">
            Contact our education coordinator for current program offerings and availability.
          </p>
        </div>
      </div>

      <div class="mt-12 text-center">
        <a href="mailto:brittany.snowden@kidscommons.org">
          <Button client:load size="lg">Contact Education Coordinator</Button>
        </a>
      </div>
    </div>
  </section>
</Layout>
