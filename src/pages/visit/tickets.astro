---
import Layout from "@/layouts/main.astro"
import PageHeader from "@/components/PageHeader.astro"
import { Button } from "@/components/ui/button"
import { SITE } from "@/lib/constants"
---

<Layout title="Session Tickets | KidsCommons">
  <PageHeader
    title="Session Tickets"
    description="Purchase timed-entry tickets for your visit."
    breadcrumbs={[
      { label: "Visit", href: "/visit" },
      { label: "Session Tickets", href: "/visit/tickets" },
    ]}
  />

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <div class="rounded-2xl border bg-card p-8 sm:p-12">
        <h2 class="text-2xl font-bold">Ready to Visit?</h2>
        <p class="mt-4 text-muted-foreground">
          We use timed-entry sessions to ensure the best experience for all visitors.
          Select your preferred date and session time through our online ticketing system.
        </p>
        <div class="mt-8">
          <a href={SITE.ticketsUrl} target="_blank" rel="noopener noreferrer">
            <Button client:load size="lg" className="px-8">
              View Available Sessions
            </Button>
          </a>
        </div>
        <p class="mt-6 text-sm text-muted-foreground">
          Members don't need tickets — just check in at the front desk.
          <a href="/memberships" class="text-primary underline"> Become a member</a>.
        </p>
      </div>
    </div>
  </section>
</Layout>
