---
import Layout from "@/layouts/main.astro"
import PageHeader from "@/components/PageHeader.astro"
import { Button } from "@/components/ui/button"
---

<Layout title="Volunteer | KidsCommons">
  <PageHeader
    title="Volunteer"
    description="Share your time and talents to help kids explore, create, and discover."
    breadcrumbs={[
      { label: "Support", href: "/support/donate" },
      { label: "Volunteer", href: "/support/volunteer" },
    ]}
  />

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <div class="rounded-2xl border bg-kc-green/5 p-8 sm:p-12">
        <h2 class="text-2xl font-bold">Why Volunteer?</h2>
        <p class="mt-4 text-muted-foreground">
          Volunteers are the heart of KidsCommons. Whether you help with exhibits,
          events, or behind the scenes, your time makes a real difference in the lives of
          children and families in our community.
        </p>
      </div>

      <div class="mt-12">
        <h2 class="text-2xl font-bold">How to Get Started</h2>
        <div class="mt-6 space-y-4">
          <div class="flex gap-4 rounded-xl border bg-card p-6">
            <span class="flex size-8 shrink-0 items-center justify-center rounded-full bg-kc-blue text-sm font-bold text-white">1</span>
            <div>
              <h3 class="font-semibold">Submit an Application</h3>
              <p class="mt-1 text-sm text-muted-foreground">
                Fill out our volunteer application form to get started.
              </p>
            </div>
          </div>
          <div class="flex gap-4 rounded-xl border bg-card p-6">
            <span class="flex size-8 shrink-0 items-center justify-center rounded-full bg-kc-red text-sm font-bold text-white">2</span>
            <div>
              <h3 class="font-semibold">Orientation & Training</h3>
              <p class="mt-1 text-sm text-muted-foreground">
                Complete a brief orientation to learn about the museum and your role.
              </p>
            </div>
          </div>
          <div class="flex gap-4 rounded-xl border bg-card p-6">
            <span class="flex size-8 shrink-0 items-center justify-center rounded-full bg-kc-green text-sm font-bold text-white">3</span>
            <div>
              <h3 class="font-semibold">Start Volunteering!</h3>
              <p class="mt-1 text-sm text-muted-foreground">
                Sign up for shifts and events through our volunteer platform.
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-12 flex flex-wrap gap-4">
        <!-- TODO: Replace with on-site form -->
        <a href="/about/contact">
          <Button client:load size="lg">Apply to Volunteer</Button>
        </a>
      </div>
    </div>
  </section>
</Layout>
