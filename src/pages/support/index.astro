---
import Layout from "@/layouts/main.astro"
import PageHeader from "@/components/PageHeader.astro"
import InfoCard from "@/components/InfoCard.astro"
---

<Layout title="Support KidsCommons">
  <PageHeader
    title="Support KidsCommons"
    description="Your generosity keeps our doors open and our programs running."
  />

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-6 sm:grid-cols-3">
      <InfoCard
        title="Donate"
        description="Every gift helps us inspire children and strengthen our community."
        href="/support/donate"
        color="red"
      />
      <InfoCard
        title="Volunteer"
        description="Share your time and talents to help kids explore and discover."
        href="/support/volunteer"
        color="green"
      />
      <InfoCard
        title="Kroger Rewards"
        description="Support us every time you shop — at no extra cost to you."
        href="/support/kroger-rewards"
        color="blue"
      />
    </div>
  </section>
</Layout>
