---
import Layout from "@/layouts/main.astro"
import PageHeader from "@/components/PageHeader.astro"
import InfoCard from "@/components/InfoCard.astro"
---

<Layout title="About | KidsCommons">
  <PageHeader
    title="About KidsCommons"
    description="A 501(c)(3) nonprofit children's museum in Columbus, Indiana."
  />

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <InfoCard
        title="Mission & History"
        description="Our story from founding to today."
        href="/about/mission-history"
        color="blue"
      />
      <InfoCard
        title="Our Team"
        description="Meet the people who make KidsCommons possible."
        href="/about/team"
        color="blue"
      />
      <InfoCard
        title="Board of Directors"
        description="Our volunteer board guiding the museum's future."
        href="/about/board"
        color="green"
      />
      <InfoCard
        title="Annual Report"
        description="See our impact and financials."
        href="/about/annual-report"
        color="purple"
      />
      <InfoCard
        title="Employment"
        description="Join our team and inspire the next generation."
        href="/about/employment"
        color="red"
      />
      <InfoCard
        title="Contact Us"
        description="Get in touch — we'd love to hear from you."
        href="/about/contact"
        color="blue"
      />
    </div>
  </section>
</Layout>
