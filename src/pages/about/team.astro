---
import Layout from "@/layouts/main.astro"
import PageHeader from "@/components/PageHeader.astro"
---

<Layout title="Our Team | KidsCommons">
  <PageHeader
    title="Our Team"
    description="Meet the people who bring KidsCommons to life every day."
    breadcrumbs={[
      { label: "About", href: "/about" },
      { label: "Our Team", href: "/about/team" },
    ]}
  />

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <!-- TODO: Team members from CMS -->
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      <div class="text-center">
        <div class="mx-auto size-40 overflow-hidden rounded-full bg-muted">
          <!-- TODO: Photo -->
        </div>
        <h3 class="mt-4 text-lg font-semibold">Whitney Hartwell</h3>
        <p class="text-sm text-kc-blue">Executive Director</p>
        <p class="mt-2 text-sm text-muted-foreground">
          <a href="mailto:whitney.hartwell@kidscommons.org" class="hover:underline">
            whitney.hartwell@kidscommons.org
          </a>
        </p>
      </div>

      <div class="text-center">
        <div class="mx-auto size-40 overflow-hidden rounded-full bg-muted">
          <!-- TODO: Photo -->
        </div>
        <h3 class="mt-4 text-lg font-semibold">Brittany Snowden</h3>
        <p class="text-sm text-kc-blue">Education Coordinator</p>
        <p class="mt-2 text-sm text-muted-foreground">
          <a href="mailto:brittany.snowden@kidscommons.org" class="hover:underline">
            brittany.snowden@kidscommons.org
          </a>
        </p>
      </div>

      <!-- Placeholder for additional team members -->
      <div class="text-center">
        <div class="mx-auto size-40 overflow-hidden rounded-full bg-muted">
          <!-- TODO: Photo -->
        </div>
        <h3 class="mt-4 text-lg font-semibold">Team Member</h3>
        <p class="text-sm text-kc-blue">Title</p>
      </div>
    </div>
  </section>
</Layout>
