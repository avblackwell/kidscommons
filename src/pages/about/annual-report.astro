---
import Layout from "@/layouts/main.astro"
import PageHeader from "@/components/PageHeader.astro"
---

<Layout title="Annual Report | KidsCommons">
  <PageHeader
    title="Annual Report"
    description="See how your support makes a difference."
    breadcrumbs={[
      { label: "About", href: "/about" },
      { label: "Annual Report", href: "/about/annual-report" },
    ]}
  />

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <!-- TODO: Replace with embedded PDF or accessible HTML version -->
      <div class="rounded-2xl border bg-card p-8 text-center">
        <h2 class="text-2xl font-bold">2024 Annual Report</h2>
        <p class="mt-4 text-muted-foreground">
          Our annual report highlights the impact of your support, including attendance,
          programs delivered, community partnerships, and financial transparency.
        </p>
        <div class="mt-8">
          <!-- TODO: Link to downloadable PDF -->
          <a
            href="#"
            class="inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
          >
            <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
              <polyline points="7 10 12 15 17 10" />
              <line x1="12" y1="15" x2="12" y2="3" />
            </svg>
            Download PDF
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
