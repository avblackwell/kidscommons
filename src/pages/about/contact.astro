---
import Layout from "@/layouts/main.astro"
import PageHeader from "@/components/PageHeader.astro"
import ContactForm from "@/components/ContactForm"
import Facebook from "@/components/icons/Facebook.astro"
import Instagram from "@/components/icons/Instagram.astro"
import { SITE } from "@/lib/constants"
---

<Layout title="Contact Us | KidsCommons">
  <PageHeader
    title="Contact Us"
    description="We'd love to hear from you."
    breadcrumbs={[
      { label: "About", href: "/about" },
      { label: "Contact Us", href: "/about/contact" },
    ]}
  />

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-5">
      <!-- Contact Info -->
      <div class="lg:col-span-2">
        <h2 class="text-2xl font-bold">Get in Touch</h2>

        <div class="mt-8 space-y-6">
          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wider text-muted-foreground">Address</h3>
            <p class="mt-2">{SITE.address.street}</p>
            <p>{SITE.address.city}, {SITE.address.state} {SITE.address.zip}</p>
          </div>

          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wider text-muted-foreground">Phone</h3>
            <p class="mt-2">
              <a href={`tel:${SITE.phone}`} class="text-primary hover:underline">{SITE.phone}</a>
            </p>
          </div>

          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wider text-muted-foreground">Email</h3>
            <p class="mt-2">
              <a href={`mailto:${SITE.email}`} class="text-primary hover:underline">{SITE.email}</a>
            </p>
          </div>

          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wider text-muted-foreground">Hours</h3>
            <div class="mt-2 space-y-1 text-sm">
              {SITE.hours.map((schedule) => (
                <div class="flex justify-between gap-4">
                  <span>{schedule.days}</span>
                  <span class="text-muted-foreground">{schedule.time}</span>
                </div>
              ))}
            </div>
          </div>

          <div class="flex gap-4 pt-2">
            <a
              href={SITE.social.facebook}
              target="_blank"
              rel="noopener noreferrer"
              class="text-muted-foreground transition-colors hover:text-foreground"
              aria-label="Facebook"
            >
              <Facebook />
            </a>
            <a
              href={SITE.social.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="text-muted-foreground transition-colors hover:text-foreground"
              aria-label="Instagram"
            >
              <Instagram />
            </a>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="lg:col-span-3">
        <div class="rounded-2xl border bg-card p-6 sm:p-8">
          <h2 class="text-2xl font-bold">Send a Message</h2>
          <p class="mt-2 text-sm text-muted-foreground">
            Fill out the form below and we'll get back to you as soon as possible.
          </p>
          <div class="mt-8">
            <ContactForm client:visible />
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
