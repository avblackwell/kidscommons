---
import Layout from "@/layouts/main.astro"
import LinkButton from "@/components/LinkButton.astro"
---

<Layout title="Page Not Found | KidsCommons">
  <section class="relative mx-auto flex min-h-[60vh] max-w-7xl flex-col items-center justify-center px-4 py-24 text-center sm:px-6 lg:px-8">
    <!-- Decorative circles -->
    <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="absolute top-12 left-12 size-32 rounded-full bg-kc-red/5" />
      <div class="absolute bottom-12 right-16 size-24 rounded-full bg-kc-blue/5" />
      <div class="absolute top-1/3 right-1/4 size-16 rounded-full bg-kc-purple/5" />
      <div class="absolute bottom-1/4 left-1/3 size-20 rounded-full bg-kc-green/5" />
    </div>

    <div class="relative">
      <div class="flex items-center justify-center gap-3">
        <div class="size-6 rounded-full bg-kc-red" />
        <div class="size-6 rounded-full bg-kc-blue" />
        <div class="size-6 rounded-full bg-kc-purple" />
        <div class="size-6 rounded-full bg-kc-green" />
      </div>
      <h1 class="mt-8 text-6xl font-extrabold tracking-tight sm:text-8xl">404</h1>
      <p class="mt-4 text-xl text-muted-foreground">Oops! This page wandered off to explore.</p>
      <p class="mt-2 text-muted-foreground">Let's get you back to the fun.</p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <LinkButton href="/" size="lg">Back to Home</LinkButton>
        <LinkButton href="/visit" variant="outline" size="lg">Plan Your Visit</LinkButton>
      </div>
    </div>
  </section>
</Layout>
